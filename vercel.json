{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nuxtjs",
  "installCommand": "corepack enable && pnpm install --frozen-lockfile",
  "buildCommand": "corepack enable && pnpm install --frozen-lockfile && NITRO_PRESET=vercel pnpm build",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "gh-pages": false
    }
  }
}