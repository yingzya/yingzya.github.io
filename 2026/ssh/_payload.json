[{"data":1,"prerenderedAt":281},["ShallowReactive",2],{"/2026/ssh":3,"surround-/2026/ssh":275},{"id":4,"title":5,"body":6,"categories":253,"date":255,"description":256,"draft":257,"extension":258,"image":259,"meta":260,"navigation":261,"path":262,"readingTime":263,"recommend":268,"references":268,"seo":269,"sitemap":270,"stem":271,"tags":272,"type":268,"updated":255,"url":268,"__hash__":274},"content/posts/2026/ssh.md","反向SSH内网服务器远程连接",{"type":7,"value":8,"toc":246},"minimark",[9,14,21,28,31,37,43,49,52,63,66,73,80,90,93,96,101,109,130,135,141,144,147,153,160,167,173,183,189,192,195,201,204,210,213,216,222,228,231,237,240],[10,11,13],"h3",{"id":12},"反向-ssh-的原理","反向 SSH 的原理",[15,16,17],"p",{},[18,19,20],"strong",{},"什么是反向SSH？",[15,22,23,24,27],{},"反向 SSH（Reverse SSH）是一种通过",[18,25,26],{},"中间公网服务器建立隧道","，从外网访问位于内网或防火墙后的服务器的方法。\n它常用于实验室或公司内部服务器没有公网 IP 的情况，保证可以安全远程管理。",[15,29,30],{},"假设你的场景：",[15,32,33,36],{},[18,34,35],{},"实验室服务器","（内网 / 防火墙后） → 无公网直接访问能力",[15,38,39,42],{},[18,40,41],{},"你的公网服务器","（有公网 IP，可以被访问）",[15,44,45,48],{},[18,46,47],{},"本地电脑"," → 想远程操作实验室服务器",[15,50,51],{},"流程：",[53,54,60],"pre",{"className":55,"code":57,"language":58,"meta":59},[56],"language-txt","实验室服务器 ---[SSH Out]-> 公网服务器 ---[你本地 SSH]-> 公网服务器 ---[隧道]-> 实验室服务器\n","txt","",[61,62,57],"code",{"__ignoreMap":59},[15,64,65],{},"核心概念：",[15,67,68,69,72],{},"1.",[18,70,71],{},"实验室服务器主动连接","公网服务器（出站，不受防火墙限制）",[15,74,75,76,79],{},"2.建立一个 ",[18,77,78],{},"反向隧道","：",[81,82,83,87],"ul",{},[84,85,86],"li",{},"在公网服务器上开一个端口（比如 2222）",[84,88,89],{},"映射回实验室服务器的 SSH（22）",[15,91,92],{},"3.本地通过公网服务器的这个端口，就能访问实验室服务器",[10,94,95],{"id":95},"命令示例",[15,97,98],{},[18,99,100],{},"1.实验室服务器上执行（建立反向隧道）",[53,102,107],{"className":103,"code":105,"language":106,"meta":59},[104],"language-bash","ssh -N -R 2222:localhost:22 user@自己服务器公网IP\n","bash",[61,108,105],{"__ignoreMap":59},[81,110,111,121,127],{},[84,112,113,116,117,120],{},[61,114,115],{"code":115},"-R 2222:localhost:22"," → 在 ",[18,118,119],{},"公网服务器"," 上开 2222 映射到实验室服务器的 22",[84,122,123,126],{},[61,124,125],{"code":125},"-N"," → 不执行远程命令，只建立隧道",[84,128,129],{},"这个命令执行后，公网服务器的 2222 就是通向实验室服务器的“入口”",[15,131,132],{},[18,133,134],{},"2.本地电脑通过公网服务器访问实验室服务器",[53,136,139],{"className":137,"code":138,"language":106,"meta":59},[104],"ssh -p 2222 user@自己服务器公网IP\n",[61,140,138],{"__ignoreMap":59},[15,142,143],{},"这里user可以是实验室服务器上已经存在的用户，执行完，输入其密码，即可进行连接。",[10,145,146],{"id":146},"注意事项",[15,148,149,150],{},"1、",[18,151,152],{},"保持反向隧道长期在线",[15,154,155,156,159],{},"普通 ",[61,157,158],{"code":158},"ssh -R"," 会话一旦断开，隧道就消失",[15,161,162,163,166],{},"使用 ",[61,164,165],{"code":165},"autossh"," 可以自动重连：",[53,168,171],{"className":169,"code":170,"language":106,"meta":59},[104],"autossh -M 0 -N -f -o \"ServerAliveInterval 30\" -o \"ServerAliveCountMax 3\" -R 2222:localhost:22 user@公网服务器IP\n",[61,172,170],{"__ignoreMap":59},[15,174,175,178,179,182],{},[61,176,177],{"code":177},"-f"," → 后台运行\n",[61,180,181],{"code":181},"ServerAliveInterval / ServerAliveCountMax"," → 避免意外断开",[15,184,185,186],{},"2、",[18,187,188],{},"公网服务器防火墙/安全组",[15,190,191],{},"必须放行 TCP 2222（或你选择的端口）",[15,193,194],{},"在阿里云/腾讯云等，需要在安全组中添加规则",[15,196,197,198],{},"3、",[18,199,200],{},"实验室服务器网络必须可用",[15,202,203],{},"即便是内网，也需要能发起外网连接（WIFI 或有出站权限的网线）",[15,205,206,207],{},"4、",[18,208,209],{},"多端口或多用户场景",[15,211,212],{},"可以映射多个端口，例如 2223 → lab2、2224 → lab3",[15,214,215],{},"每个端口对应实验室不同服务器或用户",[15,217,218,219],{},"5、",[18,220,221],{},"安全性建议",[15,223,162,224,227],{},[18,225,226],{},"SSH 密钥","代替密码，提高安全性",[15,229,230],{},"隧道端口最好只绑定公网服务器 localhost 或指定 IP，避免被外网扫描。",[15,232,233,234],{},"6、",[18,235,236],{},"掉线与重启问题",[15,238,239],{},"如果实验室服务器重启，隧道会消失",[15,241,242,243,245],{},"可以在实验室服务器设置 systemd service 启动 ",[61,244,165],{"code":165}," 保持隧道",{"title":59,"searchDepth":247,"depth":247,"links":248},4,[249,251,252],{"id":12,"depth":250,"text":13},3,{"id":95,"depth":250,"text":95},{"id":146,"depth":250,"text":146},[254],"配置","2026-03-01 16:33:42","在实验室服务器没有外网IP的情况下，通过反向SSH来远程操作实验室服务器",false,"md","https://assets.yangzy.top/Reverse_SSH.webp",{},true,"/2026/ssh",{"text":264,"minutes":265,"time":266,"words":267},"4 min read",3.535,212100,707,null,{"title":5,"description":256},{"loc":262},"posts/2026/ssh",[273],"SSH","E0WdT647Ayef2RRTPZdmU9onL5Ly_NNzztjccEn-6R4",[276,268],{"title":277,"path":278,"stem":279,"date":280,"type":268,"children":-1},"Paper Reading：Hallucination","/2025/llm-cd","posts/2025/llm-cd","2025-11-19 17:36:47",1772438947310]